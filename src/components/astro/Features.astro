---
---

<section id="features" class="py-24 sm:py-32 lg:py-40">
  <div class="container-page">
    <!-- Section Header -->
    <div class="text-center mb-16 sm:mb-20" data-reveal="fade-up">
      <span class="label mb-3 block" data-i18n="features.label">Características</span>
      <h2 class="heading-lg" data-i18n="features.title">Todo lo que necesitas</h2>
      <p class="text-body mt-4 max-w-lg mx-auto" data-i18n="features.subtitle">
        De cualquier audio o video a documentos profesionales en minutos.
      </p>
    </div>

    <!-- 6-card grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 stagger">

      <!-- 01 Transcription -->
      <div class="feature-card surface p-7 sm:p-8 rounded-xl group" data-reveal="fade-up">
        <div class="relative z-10">
          <div class="w-11 h-11 rounded-xl bg-[var(--accent-subtle)] flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
          </div>
          <h3 class="heading-md mb-2" data-i18n="features.transcribe.title">Transcripción Dual</h3>
          <p class="text-small leading-relaxed" data-i18n="features.transcribe.desc">
            Elige entre Whisper + Llama ultra-rápido (Groq) o Gemini Flash 2.0 + Pro 2.5 con razonamiento multimodal.
          </p>
        </div>
      </div>

      <!-- 02 Organization -->
      <div class="feature-card surface p-7 sm:p-8 rounded-xl group" data-reveal="fade-up">
        <div class="relative z-10">
          <div class="w-11 h-11 rounded-xl bg-[var(--accent-subtle)] flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          </div>
          <h3 class="heading-md mb-2" data-i18n="features.organize.title">Organización Inteligente</h3>
          <p class="text-small leading-relaxed" data-i18n="features.organize.desc">
            Detecta temas, extrae conceptos clave y genera resúmenes perfectamente estructurados.
          </p>
        </div>
      </div>

      <!-- 03 Export -->
      <div class="feature-card surface p-7 sm:p-8 rounded-xl group" data-reveal="fade-up">
        <div class="relative z-10">
          <div class="w-11 h-11 rounded-xl bg-[var(--accent-subtle)] flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          </div>
          <h3 class="heading-md mb-2" data-i18n="features.export.title">Exportación Premium</h3>
          <p class="text-small leading-relaxed" data-i18n="features.export.desc">
            PDFs limpios con formato académico, paginados y listos para imprimir o estudiar.
          </p>
        </div>
      </div>

      <!-- 04 Privacy -->
      <div class="feature-card surface p-7 sm:p-8 rounded-xl group" data-reveal="fade-up">
        <div class="relative z-10">
          <div class="w-11 h-11 rounded-xl bg-[var(--accent-subtle)] flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="heading-md mb-2" data-i18n="features.privacy.title">Privacidad Total</h3>
          <p class="text-small leading-relaxed" data-i18n="features.privacy.desc">
            Tus datos nunca pasan por nuestros servidores. Todo se procesa en tu navegador con tu propia API Key.
          </p>
        </div>
      </div>

      <!-- 05 Multi-format -->
      <div class="feature-card surface p-7 sm:p-8 rounded-xl group" data-reveal="fade-up">
        <div class="relative z-10">
          <div class="w-11 h-11 rounded-xl bg-[var(--accent-subtle)] flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 6 4 14"/><path d="M12 6v14"/><path d="M8 8v12"/><path d="M4 4v16"/></svg>
          </div>
          <h3 class="heading-md mb-2" data-i18n="features.multiformat.title">Multi-formato</h3>
          <p class="text-small leading-relaxed" data-i18n="features.multiformat.desc">
            Soporta MP3, MP4, WAV, M4A, WEBM, FLAC, MOV y más. Audio y video sin límites.
          </p>
        </div>
      </div>

      <!-- 06 Speed -->
      <div class="feature-card surface p-7 sm:p-8 rounded-xl group" data-reveal="fade-up">
        <div class="relative z-10">
          <div class="w-11 h-11 rounded-xl bg-[var(--accent-subtle)] flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 class="heading-md mb-2" data-i18n="features.speed.title">Ultra-rápido</h3>
          <p class="text-small leading-relaxed" data-i18n="features.speed.desc">
            Procesamiento en segundos gracias a infraestructura de IA de última generación.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
