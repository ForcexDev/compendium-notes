---
import { translations } from '../../lib/i18n';
---

<footer class="border-t border-[var(--border-subtle)] pt-16 sm:pt-20 pb-8">
  <div class="container-page">
    <!-- Top section: Brand + Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr_1fr_1fr] gap-10 sm:gap-12 mb-12">

      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg bg-[var(--accent)] flex items-center justify-center text-white overflow-hidden shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
            </svg>
          </div>
          <span class="text-sm font-bold text-[var(--text-primary)] tracking-tight" style="font-family: 'Outfit', sans-serif;">CompendiumNotes</span>
        </div>
        <p class="text-sm text-[var(--text-muted)] leading-relaxed max-w-xs mb-6" data-i18n="footer.tagline">
          Transforma cualquier audio o video en documentos estructurados con inteligencia artificial.
        </p>
        <!-- Open Source badge -->
        <div class="flex items-center gap-1.5 text-xs text-[var(--text-muted)]">
          <span data-i18n="footer.madewith">Hecho con</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#ef4444" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span>— Open Source</span>
        </div>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-sm font-medium text-[var(--text-primary)] mb-4" data-i18n="footer.product">Producto</h4>
        <ul class="space-y-2.5">
          <li><a href="/#features" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors no-underline" data-i18n="footer.features">Características</a></li>
          <li><a href="/#pricing" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors no-underline" data-i18n="footer.pricing">Precios</a></li>
          <li><a href="/app" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors no-underline">App</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-sm font-medium text-[var(--text-primary)] mb-4" data-i18n="footer.resources">Recursos</h4>
        <ul class="space-y-2.5">
          <li><a href="https://console.groq.com" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors no-underline" data-i18n="footer.groq">Consola Groq</a></li>
          <li><a href="https://aistudio.google.com" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors no-underline" data-i18n="footer.gemini">Consola Gemini</a></li>
          <li><a href="https://github.com/ForcexDev/compendium-notes" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors no-underline inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            <span data-i18n="footer.github">GitHub</span>
          </a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-medium text-[var(--text-primary)] mb-4" data-i18n="footer.legal">Legal</h4>
        <ul class="space-y-2.5">
          <li><a href="/privacy" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors no-underline" data-i18n="footer.privacy">Privacidad</a></li>
          <li><a href="/terms" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors no-underline" data-i18n="footer.terms">Términos</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <hr class="divider mb-6" />
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-[var(--text-muted)]">
        © 2026 <span data-i18n="footer.copyright">CompendiumNotes. Open Source.</span>
      </p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/ForcexDev/compendium-notes" target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
