---
---

<section id="process" class="py-24 sm:py-32 lg:py-40 border-t border-[var(--border-subtle)]">
  <div class="container-page">
    <!-- Header -->
    <div class="text-center mb-16 sm:mb-20" data-reveal="fade-up">
      <span class="label mb-3 block" data-i18n="how.label">Proceso</span>
      <h2 class="heading-lg" data-i18n="how.title">Así de simple</h2>
    </div>

    <!-- Steps with timeline -->
    <div class="relative max-w-4xl mx-auto">
      <!-- Connecting line (desktop) -->
      <div class="hidden lg:block absolute top-[28px] left-[calc(12.5%+16px)] right-[calc(12.5%+16px)] h-px bg-[var(--border-subtle)]"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6 stagger">
        <!-- Step 1 -->
        <div class="relative text-center lg:text-left" data-reveal="fade-up">
          <div class="flex flex-col items-center lg:items-start gap-4 mb-4">
            <span class="step-number flex items-center justify-center w-10 h-10 rounded-full bg-[var(--accent)] text-white text-sm font-bold shadow-lg shadow-[var(--accent)]/25 z-10 relative">1</span>
          </div>
          <h3 class="heading-md mb-2" data-i18n="how.step1.title">Elige tu IA</h3>
          <p class="text-small" data-i18n="how.step1.desc">Usa una API Key gratuita de Groq o Google Gemini.</p>
        </div>

        <!-- Step 2 -->
        <div class="relative text-center lg:text-left" data-reveal="fade-up">
          <div class="flex flex-col items-center lg:items-start gap-4 mb-4">
            <span class="step-number flex items-center justify-center w-10 h-10 rounded-full bg-[var(--accent)] text-white text-sm font-bold shadow-lg shadow-[var(--accent)]/25 z-10 relative">2</span>
          </div>
          <h3 class="heading-md mb-2" data-i18n="how.step2.title">Sube tu archivo</h3>
          <p class="text-small" data-i18n="how.step2.desc">Arrastra tu audio o video. MP3, MP4, WAV y más.</p>
        </div>

        <!-- Step 3 -->
        <div class="relative text-center lg:text-left" data-reveal="fade-up">
          <div class="flex flex-col items-center lg:items-start gap-4 mb-4">
            <span class="step-number flex items-center justify-center w-10 h-10 rounded-full bg-[var(--accent)] text-white text-sm font-bold shadow-lg shadow-[var(--accent)]/25 z-10 relative">3</span>
          </div>
          <h3 class="heading-md mb-2" data-i18n="how.step3.title">La IA organiza</h3>
          <p class="text-small" data-i18n="how.step3.desc">Transcripción y organización automática con IA.</p>
        </div>

        <!-- Step 4 -->
        <div class="relative text-center lg:text-left" data-reveal="fade-up">
          <div class="flex flex-col items-center lg:items-start gap-4 mb-4">
            <span class="step-number flex items-center justify-center w-10 h-10 rounded-full bg-[var(--accent)] text-white text-sm font-bold shadow-lg shadow-[var(--accent)]/25 z-10 relative">4</span>
          </div>
          <h3 class="heading-md mb-2" data-i18n="how.step4.title">Descarga tu PDF</h3>
          <p class="text-small" data-i18n="how.step4.desc">Edita el resultado y descarga un documento profesional.</p>
        </div>
      </div>
    </div>
  </div>
</section>
